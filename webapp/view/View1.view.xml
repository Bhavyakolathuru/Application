<mvc:View
    controllerName="test.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page title="Orders Management Table">

        <customHeader>
            <Bar>
                <contentLeft>

                    <ComboBox id="countryBox"
                        placeholder="Ship Country"
                        width="150px"
                        change="onFilterChange">
                        <items>
                            <core:Item key="" text="All"/>
                            <core:Item key="USA" text="USA"/>
                            <core:Item key="Germany" text="Germany"/>
                            <core:Item key="Brazil" text="Brazil"/>
                            <core:Item key="France" text="France"/>
                        </items>
                    </ComboBox>

                    <Input id="freightMin"
                        placeholder="Min Freight"
                        width="120px"
                        change="onFilterChange"/>

                    <Input id="freightMax"
                        placeholder="Max Freight"
                        width="120px"
                        change="onFilterChange"/>

                    <DatePicker id="dateFrom"
                        placeholder="From Date"
                        width="140px"
                        change="onFilterChange"/>

                    <DatePicker id="dateTo"
                        placeholder="To Date"
                        width="140px"
                        change="onFilterChange"/>

                </contentLeft>
            </Bar>
        </customHeader>

        <content>

           <Table
    id="tableId"
    growing="true"
    growingThreshold="20"
    growingScrollToLoad="true"
    items="{
        path: '/Orders',
        sorter: [
            { path: 'OrderDate', descending: false },
            { path: 'Freight', descending: true }
        ]
    }">

                <columns>
                    <Column><Text text="Order ID"/></Column>
                    <Column><Text text="Customer ID"/></Column>
                    <Column><Text text="Employee ID"/></Column>
                    <Column><Text text="Order Date"/></Column>
                    <Column><Text text="Required Date"/></Column>
                    <Column><Text text="Ship Country"/></Column>
                    <Column><Text text="Freight"/></Column>
                </columns>

                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{OrderID}"/>
                            <Text text="{CustomerID}"/>
                            <Text text="{EmployeeID}"/>
                            <Text text="{path:'OrderDate', formatter:'.formatDate'}"/>
                            <Text text="{path:'RequiredDate', formatter:'.formatDate'}"/>
                            <Text text="{ShipCountry}"/>
                            <Text text="{Freight}"/>
                        </cells>
                    </ColumnListItem>
                </items>

            </Table>

        </content>

    </Page>

</mvc:View>