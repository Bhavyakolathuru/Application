<mvc:View controllerName="test.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page title="Orders Management Table">

        <content>

            <Table items="{/Orders}"
                growing="true"
                growingThreshold="20"
                growingScrollToLoad="true">

                <columns>
                    <Column><Text text="Order ID"/></Column>
                    <Column><Text text="Customer ID"/></Column>
                    <Column><Text text="Employee ID"/></Column>
                    <Column><Text text="Order Date"/></Column>
                    <Column><Text text="Required Date"/></Column>
                    <Column><Text text="Ship Country"/></Column>
                    <Column><Text text="Freight"/></Column>
                </columns>

                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{OrderID}"/>
                            <Text text="{CustomerID}"/>
                            <Text text="{EmployeeID}"/>
                            <Text text="{path:'OrderDate', formatter:'.formatDate'}"/>
                            <Text text="{path:'RequiredDate', formatter:'.formatDate'}"/>
                            <Text text="{ShipCountry}"/>
                            <Text text="{Freight}"/>
                        </cells>
                    </ColumnListItem>
                </items>

            </Table>

        </content>

    </Page>
</mvc:View>